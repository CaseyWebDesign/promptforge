{
  "name": "promptforge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute promptforge-db --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute promptforge-db --file=src/db/seed.sql",
    "db:init:local": "wrangler d1 execute promptforge-db --local --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute promptforge-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "@cloudflare/workerd-windows-64": "^1.20260317.1",
    "hono": "^4.7.0",
    "puppeteer-core": "^24.40.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
